---
import type { DateRange } from "../../types/dashboard";
import { getSeoPayload } from "../../lib/queries";
import ChartBlock from "../charts/ChartBlock.astro";

interface Props {
  range: DateRange;
}

const { range } = Astro.props as Props;
const seo = await getSeoPayload(range);

const cwvConfig = {
  type: "line",
  data: {
    labels: seo.cwvHistory.map((item) => item.day),
    datasets: [
      {
        label: "LCP p75 (ms)",
        data: seo.cwvHistory.map((item) => item.lcp),
        borderColor: "#00d4ff",
        backgroundColor: "rgba(0,212,255,0.2)",
        fill: true,
        tension: 0.35
      },
      {
        label: "INP p75 (ms)",
        data: seo.cwvHistory.map((item) => item.inp),
        borderColor: "#4df2c2",
        backgroundColor: "rgba(77,242,194,0.1)",
        fill: false,
        tension: 0.35
      }
    ]
  }
};

const positionsConfig = {
  type: "bar",
  data: {
    labels: ["Top 3", "Top 10", "Top 100"],
    datasets: [
      {
        label: "Keywords",
        data: [seo.positions.top3, seo.positions.top10, seo.positions.top100],
        backgroundColor: ["rgba(0, 212, 255, 0.8)", "rgba(77, 242, 194, 0.8)", "rgba(156, 200, 255, 0.7)"]
      }
    ]
  }
};
---

<section class="space-y-4">
  <div class="flex items-end justify-between">
    <h2 class="text-xl font-semibold text-slate-100">SEO</h2>
    <p class="text-sm text-slate-300">Rango: {range.from} a {range.to}</p>
  </div>

  <div class="grid gap-4 md:grid-cols-3">
    <article class="glass-card p-4">
      <p class="text-sm text-slate-300">Top keywords (clicks)</p>
      <p class="metric-value">{seo.organicByKeyword[0]?.clicks ?? 0}</p>
      <p class="text-xs text-slate-400">{seo.organicByKeyword[0]?.keyword ?? "Sin datos"}</p>
    </article>
    <article class="glass-card p-4">
      <p class="text-sm text-slate-300">CTR promedio songs</p>
      <p class="metric-value">
        {seo.ctrByPage.length > 0
          ? `${(seo.ctrByPage.reduce((sum, row) => sum + row.ctr, 0) / seo.ctrByPage.length * 100).toFixed(2)}%`
          : "0.00%"}
      </p>
      <p class="text-xs text-slate-400">Basado en paginas de cancion</p>
    </article>
    <article class="glass-card p-4">
      <p class="text-sm text-slate-300">Indexacion media</p>
      <p class="metric-value">
        {seo.indexingVelocity.length > 0
          ? `${(seo.indexingVelocity.reduce((sum, row) => sum + row.hoursToIndex, 0) / seo.indexingVelocity.length).toFixed(1)}h`
          : "-"}
      </p>
      <p class="text-xs text-slate-400">Desde submit hasta indexed</p>
    </article>
  </div>

  <div class="grid gap-4 lg:grid-cols-2">
    <ChartBlock title="Core Web Vitals historico" subtitle="LCP e INP p75 por dia" config={cwvConfig} />
    <ChartBlock title="Posiciones Google" subtitle="Distribucion por buckets" config={positionsConfig} />
  </div>

  <article class="glass-card overflow-auto p-4">
    <h3 class="mb-3 text-base font-semibold">Trafico organico por keyword</h3>
    <table class="w-full min-w-[620px] text-sm">
      <thead>
        <tr class="text-left text-slate-400">
          <th class="pb-2">Keyword</th>
          <th class="pb-2">Clicks</th>
          <th class="pb-2">Impresiones</th>
          <th class="pb-2">Posicion media</th>
        </tr>
      </thead>
      <tbody>
        {seo.organicByKeyword.map((row) => (
          <tr class="border-t border-white/10">
            <td class="py-2 text-slate-100">{row.keyword}</td>
            <td class="py-2">{row.clicks}</td>
            <td class="py-2">{row.impressions}</td>
            <td class="py-2">{row.avgPosition}</td>
          </tr>
        ))}
      </tbody>
    </table>
  </article>
</section>
